{
  "name": "cogna",
  "displayName": "Cogna",
  "publisher": "cogna-dev",
  "description": "Run Cogna analysis, surface SARIF diagnostics, and open policy documentation from VSCode.",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:cogna.runAnalysis",
    "onCommand:cogna.refreshDiagnostics",
    "onCommand:cogna.openRuleDocumentation",
    "workspaceContains:cogna.yml",
    "workspaceContains:cogna.yaml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cogna.runAnalysis",
        "title": "Cogna: Run Analysis"
      },
      {
        "command": "cogna.refreshDiagnostics",
        "title": "Cogna: Refresh Diagnostics"
      },
      {
        "command": "cogna.openRuleDocumentation",
        "title": "Cogna: Open Rule Documentation"
      }
    ],
    "configuration": {
      "title": "Cogna",
      "properties": {
        "cogna.cliPath": {
          "type": "string",
          "default": "cogna",
          "description": "Path to the Cogna CLI executable. Relative paths resolve from the workspace root."
        },
        "cogna.workingDirectory": {
          "type": "string",
          "default": "",
          "description": "Workspace-relative or absolute directory where Cogna commands should run. Defaults to the first workspace folder."
        },
        "cogna.runOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Run Cogna analysis after saving a file in the active workspace."
        },
        "cogna.autoOpenPolicyDocs": {
          "type": "boolean",
          "default": false,
          "description": "Automatically open the first matching policy documentation link after a successful analysis refresh."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "test:unit": "npm run compile && node --test out/test/unit/*.test.js",
    "test:extension": "npm run compile && node ./out/test/runTest.js",
    "test": "npm run test:unit && npm run test:extension"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.15.18",
    "@types/vscode": "^1.96.0",
    "@vscode/test-electron": "^2.5.2",
    "glob": "^11.0.3",
    "mocha": "^11.7.1",
    "typescript": "^5.8.3",
    "vscode": "^1.1.37"
  }
}
