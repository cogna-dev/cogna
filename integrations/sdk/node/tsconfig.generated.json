{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "declaration": true,
    "outDir": "./dist/generated",
    "rootDir": "./src/generated",
    "skipLibCheck": true,
    "allowJs": false
  },
  "include": [
    "src/generated/**/*.ts"
  ]
}
