import {
  "moonbitlang/core/env" @env,
  "moonbitlang/core/encoding/utf8" @utf8,
  "moonbitlang/core/json" @json,
  "moonbitlang/x/fs" @fs,
}

options(
  "native-stub": [ "stdio_native_stub.c" ],
  targets: {
    "stdio_js.mbt": [ "js" ],
    "stdio_native.mbt": [ "native", "llvm" ],
    "stdio_wasm.mbt": [ "wasm", "wasm-gc" ],
  },
)
