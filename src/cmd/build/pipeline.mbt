///|
pub(all) enum BuildOutcome {
  RestoredLocal
  RestoredHttp
  Generated
} derive(Eq)

///|
pub(all) struct BuildExecution {
  root_dir : String
  dist_dir : String
  outcome : BuildOutcome
} derive(Eq)

///|
fn ensure_dir(path : String) -> Result[Unit, String] {
  if @fs.path_exists(path) {
    Ok(())
  } else {
    @fs.create_dir(path) catch {
      err =>
        return Err("cannot create directory \{path}: \{err.to_string()}")
    }
    Ok(())
  }
}

///|
fn write_text(path : String, content : String) -> Result[Unit, String] {
  @fs.write_string_to_file(path, content) catch {
    err => return Err("cannot write file \{path}: \{err.to_string()}")
  }
  Ok(())
}

///|
fn write_bytes(path : String, content : Bytes) -> Result[Unit, String] {
  @fs.write_bytes_to_file(path, content) catch {
    err => return Err("cannot write file \{path}: \{err.to_string()}")
  }
  Ok(())
}

///|
fn artifact_with_sha(
  path : String,
  compression : String,
  sha256 : String,
) -> Json {
  { "path": path, "sha256": sha256, "compression": compression }
}

///|
fn runtime_signature_from_env() -> Json {
  let status = match @sys.get_env_var("COGNA_SIGNATURE_STATUS") {
    Some("verified") => "verified"
    Some("untrusted") => "untrusted"
    _ => "unsigned"
  }
  let signature_value = match @sys.get_env_var("COGNA_SIGNATURE_VALUE") {
    Some(raw) => {
      let trimmed = raw.trim().to_string()
      if trimmed == "" {
        None
      } else {
        Some(trimmed)
      }
    }
    None => None
  }
  let signature : Map[String, Json] = {
    "status": Json::string(status),
    "algorithm": Json::string("sha256"),
  }
  match @sys.get_env_var("COGNA_SIGNATURE_KEY_ID") {
    Some(value) if value.trim().to_string() != "" =>
      signature["keyId"] = Json::string(value.trim().to_string())
    _ => ()
  }
  match signature_value {
    Some(value) => signature["value"] = Json::string(value)
    None => ()
  }
  Json::object(signature)
}

///|
fn pipeline_manifest_json(
  config : @config.Config,
  declarations_sha : String,
  commit : String,
  opa_bundle_sha : String?,
  policy_rules_sha : String?,
) -> Json {
  let base_artifacts : Array[Json] = [
    artifact_with_sha("declarations.ndjson", "none", declarations_sha),
  ]
  if config.profile == "policy-bundle" {
    match opa_bundle_sha {
      Some(sha) =>
        base_artifacts.push(
          artifact_with_sha("opa-bundle.tar.gz", "gzip", sha),
        )
      None => ()
    }
    match policy_rules_sha {
      Some(sha) =>
        base_artifacts.push(
          artifact_with_sha("policy.rules.json", "none", sha),
        )
      None => ()
    }
    {
      "schemaVersion": "ciq-opa-bundle/v1",
      "purl": config.purl,
      "profile": config.profile,
      "source": {
        "repo": config.source.repo,
        "ref": config.source.source_ref,
        "commit": commit,
      },
      "opa": {
        "entrypoint": "cogna/compat/deny",
        "format": "opa-bundle.tar.gz",
      },
      "provenance": {
        "checksums": "checksums.txt",
        "signature": runtime_signature_from_env(),
      },
      "artifacts": base_artifacts,
    }
  } else {
    {
      "schemaVersion": "ciq-bundle/v1",
      "purl": config.purl,
      "profile": config.profile,
      "source": {
        "repo": config.source.repo,
        "ref": config.source.source_ref,
        "commit": commit,
      },
      "artifacts": base_artifacts,
    }
  }
}

///|
fn pipeline_metadata_json(
  config : @config.Config,
  extract : ExtractOutput,
) -> Json {
  {
    "schemaVersion": "ciq-metadata/v1",
    "profile": config.profile,
    "inputPatterns": config.inputs.include_paths,
    "build": {
      "status": "completed",
      "note": "bundle generated by canonical extraction pipeline",
    },
    "extractor": {
      "role": "canonical",
      "backend": "canonical",
      "mode": extract.mode,
      "server": "canonical",
      "version": "canonical-v1",
      "fallback": extract.fallback,
      "timingMs": { "initialize": 1, "extract": 1, "normalize": 1, "total": 3 },
      "stats": {
        "declarations": extract.declaration_count,
        "diagnosticFiles": extract.diagnostic_files,
      },
    },
  }
}

///|
fn pipeline_checksums_text(
  manifest_sha : String,
  declarations_sha : String,
  metadata_sha : String,
  opa_bundle_sha : String?,
  policy_rules_sha : String?,
) -> String {
  let base = "manifest.json  \{manifest_sha}\n" +
    "declarations.ndjson  \{declarations_sha}\n" +
    "metadata.json  \{metadata_sha}\n"
  let with_opa = match opa_bundle_sha {
    Some(sha) => base + "opa-bundle.tar.gz  \{sha}\n"
    None => base
  }
  match policy_rules_sha {
    Some(sha) => with_opa + "policy.rules.json  \{sha}\n"
    None => with_opa
  }
}

///|
fn pipeline_sha256_hex(data : Bytes) -> String {
  @sha256.sha256_hexdigest(data)
}

///|
fn pipeline_utf8_bytes(text : String) -> Bytes {
  @utf8.encode(text)
}

///|
fn pipeline_octal_field(value : Int, width : Int) -> String {
  let digits = value.reinterpret_as_uint().to_string(radix=8)
  if digits.length() + 1 >= width {
    digits + "\u0000"
  } else {
    let padding = String::make(width - digits.length() - 1, '0')
    padding + digits + "\u0000"
  }
}

///|
fn pipeline_str_field(value : String, width : Int) -> String {
  let bytes = @utf8.encode(value)
  if bytes.length() >= width {
    let truncated = bytes[:width].to_bytes()
    @utf8.decode(truncated) catch { _ => value }
  } else {
    let padding = String::make(width - bytes.length(), '\u0000')
    value + padding
  }
}

///|
fn pipeline_sum_header_bytes(header : Bytes) -> Int {
  let mut total = 0
  for i in 0..<header.length() {
    total = total + header[i].to_int()
  }
  total
}

///|
fn pipeline_tar_header(name : String, size : Int) -> Bytes {
  let name_field = pipeline_str_field(name, 100)
  let mode_field = pipeline_octal_field(420, 8)
  let uid_field = pipeline_octal_field(0, 8)
  let gid_field = pipeline_octal_field(0, 8)
  let size_field = pipeline_octal_field(size, 12)
  let mtime_field = pipeline_octal_field(0, 12)
  let checksum_placeholder = "        "
  let type_flag = "0"
  let link_name = pipeline_str_field("", 100)
  let magic = "ustar\u0000"
  let version = "00"
  let uname = pipeline_str_field("", 32)
  let gname = pipeline_str_field("", 32)
  let devmajor = pipeline_octal_field(0, 8)
  let devminor = pipeline_octal_field(0, 8)
  let prefix = pipeline_str_field("", 155)
  let pad = String::make(12, '\u0000')
  let without_checksum = name_field +
    mode_field +
    uid_field +
    gid_field +
    size_field +
    mtime_field +
    checksum_placeholder +
    type_flag +
    link_name +
    magic +
    version +
    uname +
    gname +
    devmajor +
    devminor +
    prefix +
    pad
  let bytes = @utf8.encode(without_checksum)
  let checksum = pipeline_sum_header_bytes(bytes)
  let checksum_field = pipeline_octal_field(checksum, 8)
  let finalized = name_field +
    mode_field +
    uid_field +
    gid_field +
    size_field +
    mtime_field +
    checksum_field +
    type_flag +
    link_name +
    magic +
    version +
    uname +
    gname +
    devmajor +
    devminor +
    prefix +
    pad
  @utf8.encode(finalized)
}

///|
fn pipeline_tar_entry(name : String, content : Bytes) -> Bytes {
  let header = pipeline_tar_header(name, content.length())
  let payload = header.to_array()
  let content_array = content.to_array()
  for i in 0..<content_array.length() {
    payload.push(content_array[i])
  }
  let remainder = content.length() % 512
  if remainder != 0 {
    let pad = 512 - remainder
    for _ in 0..<pad {
      payload.push(b'\x00')
    }
  }
  Bytes::from_array(payload)
}

///|
fn pipeline_tar_archive(entries : Array[(String, Bytes)]) -> Bytes {
  let out : Array[Byte] = []
  for i in 0..<entries.length() {
    let (name, content) = entries[i]
    let entry_bytes = pipeline_tar_entry(name, content).to_array()
    for j in 0..<entry_bytes.length() {
      out.push(entry_bytes[j])
    }
  }
  for _ in 0..<1024 {
    out.push(b'\x00')
  }
  Bytes::from_array(out)
}

///|
fn pipeline_build_tar_payload(
  manifest_text : String,
  declarations_artifact : Bytes,
  metadata_text : String,
  checksums : String,
  opa_bundle : Bytes?,
  policy_rules : String?,
) -> Bytes {
  let entries : Array[(String, Bytes)] = [
    ("manifest.json", pipeline_utf8_bytes(manifest_text)),
    ("declarations.ndjson", declarations_artifact),
    ("metadata.json", pipeline_utf8_bytes(metadata_text)),
    ("checksums.txt", pipeline_utf8_bytes(checksums)),
  ]
  match opa_bundle {
    Some(content) => entries.push(("opa-bundle.tar.gz", content))
    None => ()
  }
  match policy_rules {
    Some(content) => entries.push(("policy.rules.json", pipeline_utf8_bytes(content)))
    None => ()
  }
  pipeline_tar_archive(entries)
}

///|
fn dependency_bundle_dir(dist_dir : String) -> String {
  "\{dist_dir}/dependencies"
}

///|
fn dependency_bundle_key(pkg : @sbom_types.Package) -> String {
  pkg
  .to_purl()
  .replace_all(old="/", new="_")
  .replace_all(old=":", new="_")
  .replace_all(old="@", new="_")
}

///|
fn bundle_parent_dir(path : String) -> String {
  let parts = path.split("/").to_array()
  if parts.length() <= 1 {
    "."
  } else {
    let mut out = ""
    for i in 0..<(parts.length() - 1) {
      if i > 0 {
        out = "\{out}/"
      }
      out = "\{out}\{parts[i]}"
    }
    if out == "" {
      "."
    } else {
      out
    }
  }
}

///|
fn ensure_nested_dir(path : String) -> Result[Unit, String] {
  let parts = path.split("/").to_array()
  let mut current = if path.has_prefix("/") { "/" } else { "" }
  for i in 0..<parts.length() {
    let segment = parts[i].to_string()
    if segment == "" {
      continue
    }
    current = if current == "" || current == "/" {
      if current == "/" {
        "/\{segment}"
      } else {
        segment
      }
    } else {
      "\{current}/\{segment}"
    }
    let out = ensure_dir(current)
    guard out is Ok(_) else { return Err(out.unwrap_err()) }
  }
  Ok(())
}

///|
fn dependency_files_json(
  root_path : String,
  files : Array[@sbom_snapshot.PackageFile],
) -> String {
  let file_records : Array[Json] = []
  for i in 0..<files.length() {
    let file = files[i]
    file_records.push({
      "path": file.path,
      "sha256": file.sha256,
      "size": file.size,
    })
  }
  (
    {
      "schemaVersion": "cogna-package-files/v1",
      "root": root_path,
      "files": Json::array(file_records),
    } : Json).stringify(indent=2)
}

///|
fn dependency_metadata_json(
  pkg : @sbom_types.Package,
  evidence_path : String,
  content_digest : String,
) -> String {
  (
    {
      "schemaVersion": "ciq-metadata/v1",
      "profile": "dependency-bundle",
      "package": {
        "id": pkg.id(),
        "name": pkg.name,
        "version": Json::string(pkg.version()),
        "purl": Json::string(pkg.to_purl()),
        "evidencePath": evidence_path,
        "contentDigest": content_digest,
      },
    } : Json).stringify(indent=2)
}

///|
fn dependency_manifest_json(
  pkg : @sbom_types.Package,
  files_sha : String,
  metadata_sha : String,
  content_digest : String,
) -> Json {
  {
    "schemaVersion": "ciq-bundle/v1",
    "purl": pkg.to_purl(),
    "profile": "openapi-spec",
    "source": {
      "repo": "local-package-cache",
      "ref": "installed",
      "commit": "sha256:\{content_digest}",
    },
    "artifacts": [
      artifact_with_sha("package.files.json", "none", files_sha),
      artifact_with_sha("metadata.json", "none", metadata_sha),
    ],
  }
}

///|
fn dependency_checksums_text(
  manifest_sha : String,
  files_sha : String,
  metadata_sha : String,
) -> String {
  "manifest.json  \{manifest_sha}\n" +
  "package.files.json  \{files_sha}\n" +
  "metadata.json  \{metadata_sha}\n"
}

///|
fn dependency_bundle_payload(
  manifest_text : String,
  files_text : String,
  metadata_text : String,
  checksums_text : String,
) -> Bytes {
  pipeline_tar_archive([
    ("manifest.json", pipeline_utf8_bytes(manifest_text)),
    ("package.files.json", pipeline_utf8_bytes(files_text)),
    ("metadata.json", pipeline_utf8_bytes(metadata_text)),
    ("checksums.txt", pipeline_utf8_bytes(checksums_text)),
  ])
}

///|
fn gzip_payload(payload : Bytes) -> Result[Bytes, String] {
  let gz = @gio.Buffer::new()
  let writer = @gzip.Writer::new(gz)
  let (_, write_out) = writer.write(@gio.Slice::new(payload.to_array()))
  guard write_out is None else {
    return Err(
      "cannot write gzip payload: \{write_out.unwrap().to_string()}",
    )
  }
  let close_out = writer.close()
  guard close_out is None else {
    return Err("cannot close gzip writer: \{close_out.unwrap().to_string()}")
  }
  Ok(gz.to_bytes())
}

///|
fn write_dependency_bundle(
  dist_dir : String,
  pkg : @sbom_types.Package,
  evidence_path : String,
) -> Result[Unit, String] {
  let root_path = @sbom_snapshot.resolve_root_path(
    bundle_parent_dir(dist_dir),
    evidence_path,
  )
  if !@sbom_snapshot.directory_exists(root_path) {
    return Ok(())
  }
  let snapshot_out = @sbom_snapshot.snapshot_files(root_path)
  guard snapshot_out is Ok(files) else { return Err(snapshot_out.unwrap_err()) }
  let content_digest = @sbom_snapshot.snapshot_digest(files)
  let bundle_dir = "\{dependency_bundle_dir(dist_dir)}/\{dependency_bundle_key(pkg)}"
  let dir_out = ensure_nested_dir(bundle_dir)
  guard dir_out is Ok(_) else { return Err(dir_out.unwrap_err()) }
  let files_text = dependency_files_json(evidence_path, files)
  let metadata_text = dependency_metadata_json(
    pkg, evidence_path, content_digest,
  )
  let files_sha = pipeline_sha256_hex(pipeline_utf8_bytes(files_text))
  let metadata_sha = pipeline_sha256_hex(pipeline_utf8_bytes(metadata_text))
  let manifest_object = dependency_manifest_json(
    pkg, files_sha, metadata_sha, content_digest,
  )
  let manifest_text = manifest_object.stringify(indent=2)
  let manifest_sha = pipeline_sha256_hex(pipeline_utf8_bytes(manifest_text))
  let checksums = dependency_checksums_text(
    manifest_sha, files_sha, metadata_sha,
  )
  let manifest_out = write_text("\{bundle_dir}/manifest.json", manifest_text)
  guard manifest_out is Ok(_) else { return Err(manifest_out.unwrap_err()) }
  let files_out = write_text("\{bundle_dir}/package.files.json", files_text)
  guard files_out is Ok(_) else { return Err(files_out.unwrap_err()) }
  let metadata_out = write_text("\{bundle_dir}/metadata.json", metadata_text)
  guard metadata_out is Ok(_) else { return Err(metadata_out.unwrap_err()) }
  let checksums_out = write_text("\{bundle_dir}/checksums.txt", checksums)
  guard checksums_out is Ok(_) else { return Err(checksums_out.unwrap_err()) }
  let tar_payload = dependency_bundle_payload(
    manifest_text, files_text, metadata_text, checksums,
  )
  let gz_out = gzip_payload(tar_payload)
  guard gz_out is Ok(gzip_bytes) else { return Err(gz_out.unwrap_err()) }
  let bundle_out = write_bytes("\{bundle_dir}/bundle.ciq.tgz", gzip_bytes)
  guard bundle_out is Ok(_) else { return Err(bundle_out.unwrap_err()) }
  Ok(())
}

///|
fn write_dependency_bundles(
  config : @config.Config,
  dist_dir : String,
  components : Array[BuildSoftwareComponent],
) -> Result[Unit, String] {
  if !config.sbom.dependency_bundles {
    return Ok(())
  }
  for i in 0..<components.length() {
    let component = components[i]
    guard component.pkg is Some(pkg) else { continue }
    if component.scope == "source-file" || component.scope == "local" {
      continue
    }
    if pkg.group == @sbom_types.DependencyGroup::Dev ||
      pkg.group == @sbom_types.DependencyGroup::Build {
      continue
    }
    match pkg.source {
      @sbom_types.DependencySource::Workspace => continue
      _ => ()
    }
    let out = write_dependency_bundle(dist_dir, pkg, component.evidence_path)
    guard out is Ok(_) else { return Err(out.unwrap_err()) }
  }
  Ok(())
}

///|
fn read_rego_from_dir(policies_dir : String) -> Result[String, String] {
  let entries = @fs.read_dir(policies_dir) catch {
    _ => return Err("cannot read policies directory: \{policies_dir}")
  }
  let rego_files : Array[String] = []
  for entry in entries {
    if entry.has_suffix(".rego") {
      rego_files.push(entry)
    }
  }
  rego_files.sort()
  let mut text = ""
  for filename in rego_files {
    let content = @fs.read_file_to_string("\{policies_dir}/\{filename}") catch {
      _ =>
        return Err("cannot read policy file \{policies_dir}/\{filename}")
    }
    text = text + content + "\n"
  }
  Ok(text)
}

///|
fn build_opa_bundle_tar_gz(
  config : @config.Config,
  repo : String,
) -> Result[(Bytes, String), String] {
  let rules = @fs.read_dir(repo) catch { _ => [] }
  let rego_files : Array[String] = []
  for i in 0..<rules.length() {
    if rules[i].has_suffix(".rego") {
      rego_files.push(rules[i])
    }
  }
  rego_files.sort()
  let policy_text = if rego_files.is_empty() {
    let fallback = read_rego_from_dir("./policies")
    guard fallback is Ok(text) else { return Err(fallback.unwrap_err()) }
    text
  } else {
    let mut text = ""
    for i in 0..<rego_files.length() {
      let content = @fs.read_file_to_string("\{repo}/\{rego_files[i]}") catch {
        _ =>
          return Err("cannot read policy file \{repo}/\{rego_files[i]}")
      }
      text = text + content + "\n"
    }
    text
  }
  let catalog_rules_out = @policy_rules.from_rego_text(policy_text)
  guard catalog_rules_out is Ok(catalog_rules) else {
    return Err(catalog_rules_out.unwrap_err().to_string())
  }
  let policy_rules_text = @policy_rules.catalog_json(catalog_rules)
  let manifest : Json = { "revision": config.purl, "roots": ["cogna"] }
  let tar_payload = pipeline_tar_archive([
    ("policy.rego", pipeline_utf8_bytes(policy_text)),
    ("data.json", pipeline_utf8_bytes("{}\n")),
    (".manifest", pipeline_utf8_bytes(manifest.stringify(indent=2))),
    ("policy.rules.json", pipeline_utf8_bytes(policy_rules_text)),
  ])
  let gz = @gio.Buffer::new()
  let writer = @gzip.Writer::new(gz)
  let (_, write_out) = writer.write(@gio.Slice::new(tar_payload.to_array()))
  guard write_out is None else {
    return Err("cannot write opa bundle gzip payload")
  }
  let close_out = writer.close()
  guard close_out is None else {
    return Err("cannot close opa bundle gzip writer")
  }
  Ok((gz.to_bytes(), policy_rules_text))
}

///|
fn write_bundle_skeleton(
  config : @config.Config,
  repo : String,
  dist_dir : String,
) -> Result[Unit, String] {
  let extract_out = extract_build(config, repo)
  guard extract_out is Ok(extract) else {
    return Err(extract_out.unwrap_err().to_string())
  }
  let declarations_artifact = pipeline_utf8_bytes(extract.declarations_text)
  let declarations_sha = pipeline_sha256_hex(declarations_artifact)
  let sbom_scan_out = collect_sbom_components(config, repo)
  guard sbom_scan_out is Ok(sbom_scan) else {
    return Err(sbom_scan_out.unwrap_err())
  }
  let sbom_artifacts = build_sbom_artifacts(sbom_scan)
  let spdx_json_text = sbom_artifacts.spdx_json
  let mut policy_rules_out : String? = None
  let opa_bundle_out = if config.profile == "policy-bundle" {
    let built = build_opa_bundle_tar_gz(config, repo)
    match built {
      Ok((bytes, rules)) => {
        policy_rules_out = Some(rules)
        Some(bytes)
      }
      Err(error) => return Err(error)
    }
  } else {
    None
  }
  let opa_bundle_sha = match opa_bundle_out {
    Some(bytes) => Some(pipeline_sha256_hex(bytes))
    None => None
  }
  let policy_rules_sha = match policy_rules_out {
    Some(text) => Some(pipeline_sha256_hex(pipeline_utf8_bytes(text)))
    None => None
  }
  let manifest_object = pipeline_manifest_json(
    config,
    declarations_sha,
    extract.commit,
    opa_bundle_sha,
    policy_rules_sha,
  )
  let manifest = manifest_object.stringify(indent=2)
  let metadata = pipeline_metadata_json(config, extract).stringify(indent=2)
  let manifest_sha = pipeline_sha256_hex(pipeline_utf8_bytes(manifest))
  let metadata_sha = pipeline_sha256_hex(pipeline_utf8_bytes(metadata))
  let checksums = pipeline_checksums_text(
    manifest_sha,
    declarations_sha,
    metadata_sha,
    opa_bundle_sha,
    policy_rules_sha,
  )
  let dir_out = ensure_dir(dist_dir)
  guard dir_out is Ok(_) else { return Err(dir_out.unwrap_err()) }
  let manifest_out = write_text("\{dist_dir}/manifest.json", manifest)
  guard manifest_out is Ok(_) else { return Err(manifest_out.unwrap_err()) }
  let decl_out = write_bytes(
    "\{dist_dir}/declarations.ndjson",
    declarations_artifact,
  )
  guard decl_out is Ok(_) else { return Err(decl_out.unwrap_err()) }
  let cogna_dir = "\{repo}/.cogna"
  let cogna_dir_out = ensure_dir(cogna_dir)
  guard cogna_dir_out is Ok(_) else { return Err(cogna_dir_out.unwrap_err()) }
  let spdx_out = write_text("\{cogna_dir}/sbom.spdx.json", spdx_json_text)
  guard spdx_out is Ok(_) else { return Err(spdx_out.unwrap_err()) }
  let metadata_out = write_text("\{dist_dir}/metadata.json", metadata)
  guard metadata_out is Ok(_) else { return Err(metadata_out.unwrap_err()) }
  let checksums_out = write_text("\{dist_dir}/checksums.txt", checksums)
  guard checksums_out is Ok(_) else { return Err(checksums_out.unwrap_err()) }
  if opa_bundle_out is Some(bundle_bytes) {
    let opa_out = write_bytes("\{dist_dir}/opa-bundle.tar.gz", bundle_bytes)
    guard opa_out is Ok(_) else { return Err(opa_out.unwrap_err()) }
  }
  if policy_rules_out is Some(rules_text) {
    let rules_out = write_text("\{dist_dir}/policy.rules.json", rules_text)
    guard rules_out is Ok(_) else { return Err(rules_out.unwrap_err()) }
  }
  let tar_payload = pipeline_build_tar_payload(
    manifest,
    declarations_artifact,
    metadata,
    checksums,
    opa_bundle_out,
    policy_rules_out,
  )
  let gz = @gio.Buffer::new()
  let writer = @gzip.Writer::new(gz)
  let (_, write_out2) = writer.write(@gio.Slice::new(tar_payload.to_array()))
  guard write_out2 is None else {
    return Err(
      "cannot write gzip payload: \{write_out2.unwrap().to_string()}",
    )
  }
  let close_out = writer.close()
  guard close_out is None else {
    return Err("cannot close gzip writer: \{close_out.unwrap().to_string()}")
  }
  let bundle_out = write_bytes("\{dist_dir}/bundle.ciq.tgz", gz.to_bytes())
  guard bundle_out is Ok(_) else { return Err(bundle_out.unwrap_err()) }
  let dependency_out = write_dependency_bundles(
    config, dist_dir, sbom_scan.components,
  )
  guard dependency_out is Ok(_) else { return Err(dependency_out.unwrap_err()) }
  Ok(())
}

///|
fn pipeline_build_cache_key(
  config : @config.Config,
  repo : String,
) -> Result[String, String] {
  let package_view_out = local_package_view(repo)
  guard package_view_out is Ok(package_view) else {
    return Err(package_view_out.unwrap_err().to_string())
  }
  let files_out = resolve_input_files_from_view(config, package_view)
  guard files_out is Ok(files) else {
    return Err(files_out.unwrap_err().to_string())
  }
  let parts : Array[String] = [
    "schema=\{config.schema_version}",
    "profile=\{config.profile}",
    "purl=\{config.purl}",
    "source.repo=\{config.source.repo}",
    "source.ref=\{config.source.source_ref}",
  ]
  for i in 0..<files.length() {
    let relative_path = files[i]
    let bytes_out = package_view.read_bytes(relative_path)
    guard bytes_out is Ok(bytes) else {
      return Err("cannot read build input \{relative_path}: \{bytes_out.unwrap_err()}")
    }
    parts.push(
      "\{relative_path} \{@sha256.sha256_hexdigest(bytes)} \{bytes.length()}",
    )
  }
  let digest = @sha256.sha256_hexdigest(@utf8.encode(parts.join("\n")))
  Ok("build/\{config.purl}/\{digest}/bundle.ciq.tgz")
}

///|
fn pipeline_cache_root_dir(config : @config.Config, root_dir : String) -> String {
  @config.resolve_project_path(root_dir, config.cache.local_store.store_dir)
}

///|
fn materialize_cached_bundle(
  dist_dir : String,
  bundle_bytes : Bytes,
) -> Result[Unit, String] {
  let dist_out = ensure_dir(dist_dir)
  guard dist_out is Ok(_) else { return Err(dist_out.unwrap_err()) }
  let bundle_path = "\{dist_dir}/bundle.ciq.tgz"
  let bundle_out = write_bytes(bundle_path, bundle_bytes)
  guard bundle_out is Ok(_) else { return Err(bundle_out.unwrap_err()) }
  let materialize_out = @bundle.materialize_bundle_tar_gz(bundle_path, dist_dir)
  guard materialize_out is Ok(_) else {
    return Err(materialize_out.unwrap_err())
  }
  Ok(())
}

///|
fn restore_bundle_from_local_cache(
  config : @config.Config,
  root_dir : String,
  cache_key : String,
  dist_dir : String,
) -> Result[Bool, String] {
  let cache_root = pipeline_cache_root_dir(config, root_dir)
  let cached_out = @local_cache.get(cache_root, cache_key)
  guard cached_out is Ok(cached) else { return Err(cached_out.unwrap_err()) }
  match cached {
    Some(object) => {
      let materialize_out = materialize_cached_bundle(dist_dir, object.body)
      guard materialize_out is Ok(_) else {
        return Err(materialize_out.unwrap_err())
      }
      Ok(true)
    }
    None => Ok(false)
  }
}

///|
fn restore_bundle_from_http_cache(
  config : @config.Config,
  root_dir : String,
  cache_key : String,
  dist_dir : String,
) -> Result[Bool, String] {
  if config.cache.type_ != "http" {
    return Ok(false)
  }
  let cached_out = @http_cache.get(config.cache.http.base_url, cache_key)
  guard cached_out is Ok(cached) else { return Err(cached_out.unwrap_err()) }
  match cached {
    Some(object) => {
      let cache_root = pipeline_cache_root_dir(config, root_dir)
      let put_out = @local_cache.put(
        cache_root,
        cache_key,
        object.body,
        content_type=object.content_type,
      )
      guard put_out is Ok(_) else { return Err(put_out.unwrap_err()) }
      let materialize_out = materialize_cached_bundle(dist_dir, object.body)
      guard materialize_out is Ok(_) else {
        return Err(materialize_out.unwrap_err())
      }
      Ok(true)
    }
    None => Ok(false)
  }
}

///|
fn store_bundle_in_local_cache(
  config : @config.Config,
  root_dir : String,
  cache_key : String,
  dist_dir : String,
) -> Result[Unit, String] {
  let bundle_path = "\{dist_dir}/bundle.ciq.tgz"
  let bundle_bytes = @fs.read_file_to_bytes(bundle_path) catch {
    err =>
      return Err("cannot read bundle file \{bundle_path}: \{err.to_string()}")
  }
  let cache_root = pipeline_cache_root_dir(config, root_dir)
  let put_out = @local_cache.put(
    cache_root,
    cache_key,
    bundle_bytes,
    content_type="application/gzip",
  )
  guard put_out is Ok(_) else { return Err(put_out.unwrap_err()) }
  Ok(())
}

///|
fn execute_build(
  config : @config.Config,
  root_dir : String,
) -> Result[BuildExecution, String] {
  let dist_dir = "\{root_dir}/dist"
  let cache_key_out = pipeline_build_cache_key(config, root_dir)
  guard cache_key_out is Ok(cache_key) else {
    return Err(cache_key_out.unwrap_err())
  }
  let restore_local_out = restore_bundle_from_local_cache(
    config, root_dir, cache_key, dist_dir,
  )
  guard restore_local_out is Ok(restored_local) else {
    return Err(restore_local_out.unwrap_err())
  }
  if restored_local {
    return Ok({ root_dir, dist_dir, outcome: BuildOutcome::RestoredLocal })
  }
  let restore_http_out = restore_bundle_from_http_cache(
    config, root_dir, cache_key, dist_dir,
  )
  guard restore_http_out is Ok(restored_http) else {
    return Err(restore_http_out.unwrap_err())
  }
  if restored_http {
    return Ok({ root_dir, dist_dir, outcome: BuildOutcome::RestoredHttp })
  }
  let write_out = write_bundle_skeleton(config, root_dir, dist_dir)
  guard write_out is Ok(_) else { return Err(write_out.unwrap_err()) }
  let cache_store_out = store_bundle_in_local_cache(
    config, root_dir, cache_key, dist_dir,
  )
  guard cache_store_out is Ok(_) else {
    return Err(cache_store_out.unwrap_err())
  }
  Ok({ root_dir, dist_dir, outcome: BuildOutcome::Generated })
}

///|
pub fn run_build(repo_hint : String) -> Result[BuildExecution, String] {
  let lookup_root = if repo_hint == "" { "." } else { repo_hint }
  let resolved_out = @config.resolve(lookup_root)
  guard resolved_out is Ok(resolved) else {
    return Err(resolved_out.unwrap_err().to_string())
  }
  execute_build(resolved.config, resolved.root_dir)
}
