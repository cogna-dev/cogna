  Some({ id, name, version, purl, component_type, scope, evidence_path, hashes, location })
}

///|
pub fn SoftwareComponent::to_json_string(self : SoftwareComponent) -> Result[String, String] {
  Ok(self.to_json().stringify())
}

///|
pub fn SoftwareComponent::from_json_string(s : String) -> Result[SoftwareComponent, String] {
  let parsed = try? @json.parse(s)
  guard parsed is Ok(value) else { return Err("invalid json") }
  match SoftwareComponent::from_json(value) {
    Some(out) => Ok(out)
    None => Err("type mismatch")
  }
}

///|
pub(all) struct Bundle {
  schema_version : String
  purl : String
  profile : Profile
  declaration_schema : DeclarationSchema?
  source : SourceInfo?
  metadata : BundleMetadata?
  checksums : Array[BundleChecksum]
  declarations : Array[Declaration]
  symbols : Array[Symbol]
  software_components : Array[SoftwareComponent]
  sbom_spdx_json : String
} derive(Eq)

///|
pub fn Bundle::to_json(self : Bundle) -> Json {
  let obj : Map[String, Json] = {}
  obj["schemaVersion"] = Json::string(self.schema_version)
  obj["purl"] = Json::string(self.purl)
  obj["profile"] = self.profile.to_json()
  match self.declaration_schema {
    Some(value) => obj["declarationSchema"] = value.to_json()
    None => ()
  }
  match self.source {
    Some(value) => obj["source"] = value.to_json()
    None => ()
  }
  match self.metadata {
    Some(value) => obj["metadata"] = value.to_json()
    None => ()
  }
  obj["checksums"] = Json::array(self.checksums.map(fn(item) { item.to_json() }))
  obj["declarations"] = Json::array(self.declarations.map(fn(item) { item.to_json() }))
  obj["symbols"] = Json::array(self.symbols.map(fn(item) { item.to_json() }))
  obj["softwareComponents"] = Json::array(self.software_components.map(fn(item) { item.to_json() }))
  obj["sbomSpdxJson"] = Json::string(self.sbom_spdx_json)
  Json::object(obj)
}

///|
pub fn Bundle::from_json(j : Json) -> Bundle? {
  guard j is Object(obj) else { return None }
  let schema_version : String = match obj.get("schemaVersion") {
    Some(value) => match (match value { String(text) => Some(text) ; _ => None }) {
      Some(parsed) => parsed
      None => return None
    }
    None => return None
  }
  let purl : String = match obj.get("purl") {
    Some(value) => match (match value { String(text) => Some(text) ; _ => None }) {
      Some(parsed) => parsed
      None => return None
    }
    None => return None
  }
  let profile : Profile = match obj.get("profile") {
    Some(value) => match (Profile::from_json(value)) {
      Some(parsed) => parsed
      None => return None
    }
    None => return None
  }
  let declaration_schema : DeclarationSchema? = match obj.get("declarationSchema") {
    Some(value) => (DeclarationSchema::from_json(value))
    None => None
  }
  let source : SourceInfo? = match obj.get("source") {
    Some(value) => (SourceInfo::from_json(value))
    None => None
  }
  let metadata : BundleMetadata? = match obj.get("metadata") {
    Some(value) => (BundleMetadata::from_json(value))
    None => None
  }
  let checksums : Array[BundleChecksum] = match obj.get("checksums") {
    Some(value) => match (match value {
    Array(items) => {
      let parsed : Array[BundleChecksum] = []
      for item in items {
        match (BundleChecksum::from_json(item)) {
          Some(value) => parsed.push(value)
          None => return None
        }
      }
      Some(parsed)
    }
    _ => None
  }) {
      Some(parsed) => parsed
      None => return None
    }
    None => return None
  }
  let declarations : Array[Declaration] = match obj.get("declarations") {
    Some(value) => match (match value {
    Array(items) => {
      let parsed : Array[Declaration] = []
      for item in items {
        match (Declaration::from_json(item)) {
          Some(value) => parsed.push(value)
          None => return None
        }
      }
      Some(parsed)
    }
    _ => None
  }) {
      Some(parsed) => parsed
      None => return None
    }
    None => return None
  }
  let symbols : Array[Symbol] = match obj.get("symbols") {
    Some(value) => match (match value {
    Array(items) => {
      let parsed : Array[Symbol] = []
      for item in items {
        match (Symbol::from_json(item)) {
          Some(value) => parsed.push(value)
          None => return None
        }
      }
      Some(parsed)
    }
    _ => None
  }) {
      Some(parsed) => parsed
      None => return None
    }
    None => return None
  }
  let software_components : Array[SoftwareComponent] = match obj.get("softwareComponents") {
    Some(value) => match (match value {
    Array(items) => {
      let parsed : Array[SoftwareComponent] = []
      for item in items {
        match (SoftwareComponent::from_json(item)) {
          Some(value) => parsed.push(value)
          None => return None
        }
      }
      Some(parsed)
    }
    _ => None
  }) {
      Some(parsed) => parsed
      None => return None
    }
    None => return None
  }
  let sbom_spdx_json : String = match obj.get("sbomSpdxJson") {
    Some(value) => match (match value { String(text) => Some(text) ; _ => None }) {
      Some(parsed) => parsed
      None => return None
    }
    None => return None
  }
  Some({ schema_version, purl, profile, declaration_schema, source, metadata, checksums, declarations, symbols, software_components, sbom_spdx_json })
}

///|
pub fn Bundle::to_json_string(self : Bundle) -> Result[String, String] {
  Ok(self.to_json().stringify())
}

///|
pub fn Bundle::from_json_string(s : String) -> Result[Bundle, String] {
  let parsed = try? @json.parse(s)
  guard parsed is Ok(value) else { return Err("invalid json") }
  match Bundle::from_json(value) {
    Some(out) => Ok(out)
    None => Err("type mismatch")
  }
}


