---
import Layout from "@/layouts/home.astro"
import { HomeCta } from "@/components/home/home-cta"
import { HomeFeature } from "@/components/home/home-feature"
import { HomeHero } from "@/components/home/home-hero"

const homeHero = {
  title: "Cogna",
  description:
    "以源码为单一事实来源，为 AI 和开发者提供精准的代码上下文，替代传统的文档和代码理解工具",
  actions: [
    {
      title: "快速开始",
      href: "/docs/quickstart",
      variant: "default" as const,
    },
    {
      title: "了解详情",
      href: "/docs/introduction",
      variant: "outline" as const,
    },
  ],
}

const homeFeature = {
  variant: "default" as const,
  layout: "bento" as const,
  title: "核心能力",
  description: "Cogna 以源码为中心，重建代码理解的基础设施",
  items: [
    {
      title: "AI 代码理解",
      description:
        "替代 Context7 MCP 等传统工具，直接从源码提取精准的代码上下文，让 AI 理解真实的代码结构而非依赖过时的文档",
      cover: "/images/feature-extraction.svg",
      action: {
        title: "了解详情",
        href: "/docs/mcp",
      },
      span: 1 as const,
    },
    {
      title: "源码即文档",
      description:
        "替代 Dash、DevDocs 等文档工具，以源码作为唯一的事实来源，自动生成准确的 API 参考，消除文档与代码不同步的问题",
      cover: "/images/feature-governance.svg",
      action: {
        title: "了解详情",
        href: "/docs/query-signatures",
      },
      span: 2 as const,
    },
    {
      title: "发版前检查",
      description:
        "在发布前自动检查接口变更，识别破坏性更新，确保版本兼容性。支持 Go、Rust、Terraform、OpenAPI 等多种类型仓库，轻松集成到 CI/CD 流程",
      cover: "/images/feature-cache.svg",
      action: {
        title: "了解详情",
        href: "/docs/build-indexes",
      },
      span: 3 as const,
    },
  ],
}

const homeCta = {
  title: "开始使用 Cogna，让 AI 和开发者都能准确理解你的代码",
  description:
    "支持 Go、Rust、Terraform、OpenAPI 等多种类型仓库，轻松集成到现有开发流程",
  variant: "primary" as const,
  action: {
    title: "快速开始",
    href: "/docs/quickstart",
    variant: "default" as const,
  },
}
---

<Layout title="Cogna" description="以源码为单一事实来源，重建 AI 和开发者的代码理解">
  <HomeHero client:load hero={homeHero} />
  <HomeFeature client:load feature={homeFeature} />
  <HomeCta client:load cta={homeCta} />
</Layout>
