---
import Layout from "@/layouts/home.astro"
import { HomeCta } from "@/components/home/home-cta"
import { HomeFeature } from "@/components/home/home-feature"
import { HomeHero } from "@/components/home/home-hero"

const homeHero = {
  title: "CodeIQ：把仓库变成可检查、可查询、可复用的本地上下文资产",
  description:
    "围绕 build、diff、check、query 与本地共享，把公开接口、软件成分和策略检查组织成一条可落地的单机工作流。",
  actions: [
    {
      title: "了解 CodeIQ",
      href: "/docs/introduction",
      variant: "default" as const,
    },
    {
      title: "10 分钟跑通",
      href: "/docs/quickstart",
      variant: "outline" as const,
    },
  ],
}

const homeFeature = {
  variant: "default" as const,
  layout: "bento" as const,
  title: "从用户任务出发，而不是从内部模块出发",
  description: "先跑通，再检查，再查询，再复用。",
  items: [
    {
      title: "先完成第一次成功路径",
      description:
        "先用一个真实仓库完成 build、diff、check 与 query，快速判断 CodeIQ 是否适合你的工作流。",
      cover: "/images/feature-accessible.svg",
      action: { title: "查看快速开始", href: "/docs/quickstart" },
      span: 1 as const,
    },
    {
      title: "发版前做兼容性检查",
      description:
        "把声明变化与软件成分变化整理成 CIQ Diff，再结合本地 policy bundle 输出 SARIF。",
      cover: "/images/feature-themeable.svg",
      action: { title: "查看检查流程", href: "/docs/release-check" },
      span: 1 as const,
    },
    {
      title: "让 AI / Agent 查询依赖与 API",
      description:
        "当你需要交互式查询时，推荐按 outlines → symbol 的顺序逐步缩小范围。",
      cover: "/images/feature-composable.svg",
      action: { title: "查看 AI 查询工作流", href: "/docs/mcp" },
      span: 1 as const,
    },
  ],
}

const homeCta = {
  title: "从一个真实仓库开始",
  description:
    "如果你已经认可整体方向，下一步就按用户任务阅读：第一次跑通、发版前检查、AI 查询与本地共享。",
  variant: "primary" as const,
  action: { title: "进入文档", href: "/docs/introduction" },
}
---

<Layout title="CodeIQ" description="单机、local-only 的代码接口治理与 AI 查询工作流">
	<HomeHero client:load hero={homeHero} />
	<HomeFeature client:load feature={homeFeature} />
	<HomeCta client:load cta={homeCta} />
</Layout>
