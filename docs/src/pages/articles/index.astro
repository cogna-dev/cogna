---
import Layout from "@/layouts/blog.astro"
import { BlogArticleList } from "@/components/blog/blog-article-list"
import { Container } from "@/components/primitive/container"
import { getCollection } from "astro:content"

const articles = await getCollection("articles", ({ data }) => !data.draft)
const sorted = articles.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())

const articleItems = sorted.map((article) => {
  const slug = article.id.replace(/^articles\//, "").replace(/\.mdx?$/, "")
  return {
    title: article.data.title,
    description: article.data.description,
    date: article.data.date,
    href: `/articles/${slug}`,
    cover: article.data.cover,
    author: article.data.author,
    tags: article.data.tags,
  }
})
---

<Layout title="Blog">
  <Container>
    <div class="flex flex-col items-center justify-center py-24 gap-8">
      <h1 class="text-4xl font-bold">Articles</h1>
      <p class="text-lg text-muted-foreground">Read all articles published for your site</p>
    </div>
    <div class="pb-16">
      <BlogArticleList articles={articleItems} client:load />
    </div>
  </Container>
</Layout>
