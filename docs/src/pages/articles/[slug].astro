---
import Layout from "@/layouts/blog.astro"
import { BlogArticle } from "@/components/blog/blog-article"
import { mdxComponents } from "@/components/primitive/typography"
import { getCollection, render } from "astro:content"

export async function getStaticPaths() {
  const articles = await getCollection("articles", ({ data }) => !data.draft)

  return articles.map((article) => ({
    params: {
      slug: article.id.replace(/^articles\//, "").replace(/\.mdx?$/, ""),
    },
    props: { article },
  }))
}

const { article } = Astro.props
const { Content } = await render(article)
const { title, description, date, cover, author, tags } = article.data
---

<Layout title={`${title} - XaC Labs UI`} description={description}>
  <BlogArticle
    title={title}
    description={description}
    date={date}
    cover={cover}
    author={author}
    tags={tags}
  >
    <Content components={mdxComponents} />
  </BlogArticle>
</Layout>
