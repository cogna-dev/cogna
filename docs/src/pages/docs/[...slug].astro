---
import Layout from "@/layouts/doc.astro"
import { mdxComponents } from "@/components/primitive/typography"
import { getCollection, render } from "astro:content"

export async function getStaticPaths() {
  const docs = await getCollection("docs")

  return docs.map((doc) => {
    const slug = doc.id.replace(/^docs\//, "").replace(/\.mdx?$/, "")
    return {
      params: { slug },
      props: { doc },
    }
  })
}

const { doc } = Astro.props
const { Content, headings } = await render(doc)
---

<Layout title={doc.data.title} description={doc.data.description} headings={headings}>
  <Content components={mdxComponents} />
</Layout>
