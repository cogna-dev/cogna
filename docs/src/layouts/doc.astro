---
import Base from "@/layouts/base.astro"
import { Header } from "@/components/primitive/header"
import { DocsLayout } from "@/components/doc/doc-layout"
import { Footer } from "@/components/primitive/footer"

interface Props {
  title?: string
  description?: string
  headings?: Array<{ depth: number; slug: string; text: string }>
}

const { title, description, headings = [] } = Astro.props
const currentPath = Astro.url.pathname
---

<Base title={title} description={description}>
	<Header client:load header={{
		title: "CodeIQ",
		description: "把仓库变成可检查、可查询、可复用的本地上下文资产",
		menus: [
			{ title: "了解 CodeIQ", href: "/docs/introduction" },
			{ title: "快速开始", href: "/docs/quickstart" },
			{ title: "兼容性检查", href: "/docs/release-check" },
			{ title: "开发状态", href: "/docs/progress" },
			{ title: "GitHub", href: "https://github.com/yufeiminds/codeiq" },
		],
		homeHref: "/",
	}} />
	<DocsLayout
		client:load
		title={title || ""}
		description={description}
		headings={headings}
		sidebar={[
			{
				title: "Start Here",
				items: [
					{ title: "CodeIQ 能帮我解决什么问题？", href: "/docs/introduction" },
					{ title: "第一次跑通：10 分钟完成 build → diff → check → query", href: "/docs/quickstart" },
				],
			},
			{
				title: "Common Tasks",
				items: [
					{ title: "发版前兼容性检查", href: "/docs/release-check" },
					{ title: "让 AI / Agent 查询依赖与 API", href: "/docs/mcp" },
					{ title: "在本机共享 bundle：publish / registry / materialize", href: "/docs/bundle-sharing" },
				],
			},
			{
				title: "Core Concepts",
				items: [
					{ title: "理解 CodeIQ 产物：Config / Bundle / OPA Bundle / Diff / Result / SARIF", href: "/docs/indexing" },
					{ title: "理解 Local Registry、PURL 与 local query runtime", href: "/docs/runtime-model" },
					{ title: "支持范围与当前限制", href: "/docs/providers" },
				],
			},
			{
				title: "Reference & Status",
				items: [
					{ title: "CLI Reference", href: "/docs/cli" },
					{ title: "MCP / Registry Reference", href: "/docs/runtime-reference" },
					{ title: "Progress / Product Status", href: "/docs/progress" },
				],
			},
		]}
		currentPath={currentPath}
	>
		<slot />
	</DocsLayout>
	<Footer client:load footer={{
		title: "CodeIQ",
		description: "单机、local-only 的代码接口治理与 AI 查询工作流。",
		menus: [
			{
				title: "Start Here",
				children: [
					{ title: "CodeIQ 能帮我解决什么问题？", href: "/docs/introduction" },
					{ title: "第一次跑通", href: "/docs/quickstart" },
					{ title: "发版前兼容性检查", href: "/docs/release-check" },
					{ title: "让 AI / Agent 查询依赖与 API", href: "/docs/mcp" },
				],
			},
			{
				title: "Reference & Status",
				children: [
					{ title: "CLI Reference", href: "/docs/cli" },
					{ title: "MCP / Registry Reference", href: "/docs/runtime-reference" },
					{ title: "Progress / Product Status", href: "/docs/progress" },
					{ title: "GitHub", href: "https://github.com/yufeiminds/codeiq" },
				],
			},
		],
		copyright: "CodeIQ",
	}} socials={{}} />
</Base>
