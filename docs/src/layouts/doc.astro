---
import Base from "@/layouts/base.astro"
import { Header } from "@/components/primitive/header"
import { DocsLayout } from "@/components/doc/doc-layout"
import { Footer } from "@/components/primitive/footer"
import { footerMenus, topNavigation, userSidebar } from "@/lib/navigation"

interface Props {
  title?: string
  description?: string
  headings?: Array<{ depth: number; slug: string; text: string }>
}

const { title, description, headings = [] } = Astro.props
const currentPath = Astro.url.pathname
---

<Base title={title} description={description}>
	<Header client:load header={{
			 title: "Cogna",
		description: "面向声明与变更治理的本地工作流",
		menus: topNavigation,
		homeHref: "/",
	}} />
	<DocsLayout
		client:load
		title={title || ""}
		description={description}
		headings={headings}
		sidebar={userSidebar}
		currentPath={currentPath}
	>
		<slot />
	</DocsLayout>
	<Footer client:load footer={{
			 title: "Cogna",
		description: "Tutorials / How-to / Reference / Explanation",
		menus: footerMenus,
			 copyright: "Cogna",
	}} socials={{}} />
</Base>
