---
import Base from "@/layouts/base.astro"
import { Header } from "@/components/primitive/header"
import { DocsLayout } from "@/components/doc/doc-layout"
import { Footer } from "@/components/primitive/footer"

interface Props {
  title?: string
  description?: string
  headings?: Array<{ depth: number; slug: string; text: string }>
}

const { title, description, headings = [] } = Astro.props
const currentPath = Astro.url.pathname
---

<Base title={title} description={description}>
	<Header client:load header={{
		title: "CodeIQ",
		description: "云、端一体的代码理解平台",
		menus: [
			{ title: "概览", href: "/docs/introduction" },
			{ title: "快速开始", href: "/docs/quickstart" },
			{ title: "GitHub", href: "https://github.com/yufeiminds/codeiq" },
		],
		homeHref: "/",
	}} />
	<DocsLayout
		client:load
		title={title || ""}
		description={description}
		headings={headings}
		sidebar={[
			{
				title: "开始使用",
				items: [
					{ title: "概览", href: "/docs/introduction" },
					{ title: "快速开始", href: "/docs/quickstart" },
				],
			},
			{
				title: "核心能力",
				items: [
					{ title: "索引与紧凑上下文", href: "/docs/indexing" },
					{ title: "MCP 工作流", href: "/docs/mcp" },
				],
			},
			{
				title: "参考",
				items: [
					{ title: "CLI 参考", href: "/docs/cli" },
				],
			},
		]}
		currentPath={currentPath}
	>
		<slot />
	</DocsLayout>
	<Footer client:load footer={{
		title: "CodeIQ",
		description: "面向大规模代码库的符号级索引与 AI 上下文服务。",
		menus: [
			{
				title: "文档",
				children: [
					{ title: "概览", href: "/docs/introduction" },
					{ title: "快速开始", href: "/docs/quickstart" },
					{ title: "CLI 参考", href: "/docs/cli" },
				],
			},
			{
				title: "更多",
				children: [
					{ title: "MCP 工作流", href: "/docs/mcp" },
					{ title: "功能成熟度", href: "/docs/roadmap" },
					{ title: "GitHub", href: "https://github.com/yufeiminds/codeiq" },
				],
			},
		],
		copyright: "CodeIQ",
	}} socials={{}} />
</Base>
