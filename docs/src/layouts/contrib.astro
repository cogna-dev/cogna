---
import Base from "@/layouts/base.astro"
import { Header } from "@/components/primitive/header"
import { DocsLayout } from "@/components/doc/doc-layout"
import { Footer } from "@/components/primitive/footer"
import { contributorSidebar, footerMenus, topNavigation } from "@/lib/navigation"

interface Props {
  title?: string
  description?: string
  headings?: Array<{ depth: number; slug: string; text: string }>
}

const { title, description, headings = [] } = Astro.props
const currentPath = Astro.url.pathname
---

<Base title={title} description={description}>
	<Header client:load header={{
		title: "CodeIQ",
		description: "贡献者文档与内部参考",
		menus: topNavigation,
		homeHref: "/",
	}} />
	<DocsLayout
		client:load
		title={title || ""}
		description={description}
		headings={headings}
		sidebar={contributorSidebar}
		currentPath={currentPath}
	>
		<slot />
	</DocsLayout>
	<Footer client:load footer={{
		title: "CodeIQ",
		description: "贡献者文档与内部参考",
		menus: footerMenus,
		copyright: "CodeIQ",
	}} socials={{}} />
</Base>
